// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RunStatus {
  pending
  enriching
  scoring
  complete
  failed
}

enum EnrichmentStatus {
  success
  failed
  skipped
}

model ScoringModel {
  id        String   @id @default(uuid())
  name      String
  criteria  Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  runs      Run[]

  @@map("scoring_models")
}

model Run {
  id                  String        @id @default(uuid())
  modelId             String?       @map("model_id")
  model               ScoringModel? @relation(fields: [modelId], references: [id])
  originalFilename    String        @map("original_filename")
  totalContacts       Int           @default(0) @map("total_contacts")
  enrichedCount       Int           @default(0) @map("enriched_count")
  failedCount         Int           @default(0) @map("failed_count")
  status              RunStatus     @default(pending)
  aiSuggestedCriteria Json?         @map("ai_suggested_criteria")
  scoringCriteria     Json?         @map("scoring_criteria")
  avgEnrichmentMs     Int?          @map("avg_enrichment_ms")
  totalEnrichmentMs   Int?          @map("total_enrichment_ms")
  createdAt           DateTime      @default(now()) @map("created_at")
  completedAt         DateTime?     @map("completed_at")
  results             RunResult[]

  @@map("runs")
}

model RunResult {
  id               String           @id @default(uuid())
  runId            String           @map("run_id")
  run              Run              @relation(fields: [runId], references: [id])
  rowIndex         Int              @map("row_index")
  linkedinUrl      String           @map("linkedin_url")
  enrichedData     Json?            @map("enriched_data")
  enrichmentStatus EnrichmentStatus @map("enrichment_status")
  totalScore       Decimal?         @map("total_score")
  criterionScores  Json?            @map("criterion_scores")
  createdAt        DateTime         @default(now()) @map("created_at")

  @@map("run_results")
}
